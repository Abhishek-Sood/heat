# Database Configuration
POSTGRES_DB=heat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://postgres:root@localhost:5432/heat

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-make-it-long-and-secure
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Keys
GROQ_API_KEY=your-groq-api-key-here

# MCP Server Configuration
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=9000

# Application Configuration
API_PREFIX=/api
PROJECT_NAME=GenAI Clinical Assistant
VERSION=1.0.0
CHROMA_DB_PATH=/chroma-data
MED42_MODEL=m42-health/med42-70b
GROQ_MODEL=llama-3.1-8b-instant