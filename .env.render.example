# Render Deployment Environment Variables
# Copy this to your Render dashboard environment variables

# =========================
# REQUIRED - Set Manually
# =========================
# Your GROQ API key for LLM operations
GROQ_API_KEY=your-groq-api-key-here

# =========================
# AUTO-CONFIGURED BY RENDER
# =========================
# These are automatically set when using render.yaml Blueprint
# DATABASE_URL - PostgreSQL connection string (from Render DB)
# SECRET_KEY - Auto-generated JWT secret
# POSTGRES_* - Database credentials (from Render DB)

# =========================
# OPTIONAL OVERRIDES
# =========================
# MCP Server Configuration
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=9000
SKIP_MCP_CHECK=false

# JWT Configuration  
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
CHROMA_DB_PATH=/app/chroma_data
GROQ_MODEL=llama-3.1-8b-instant
API_PREFIX=/api
PROJECT_NAME=GenAI Clinical Assistant
VERSION=1.0.0
